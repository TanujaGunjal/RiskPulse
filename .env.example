# ============================================================================
# Django Settings Environment Variables
# ============================================================================

# Security
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.herokuapp.com

# Django Log Level
DJANGO_LOG_LEVEL=INFO

# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================

DB_ENGINE=django.db.backends.postgresql
DB_NAME=riskpulse_db
DB_USER=riskpulse_user
DB_PASSWORD=your-database-password-here
DB_HOST=localhost
DB_PORT=5432

# Alternative: Use SQLite for development
# Uncomment below and comment out PostgreSQL settings above
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# ============================================================================
# CORS Configuration
# ============================================================================

# Frontend URL for CORS allowlist
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Email Configuration
# ============================================================================

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=noreply@riskpulse.com

# ============================================================================
# Caching Configuration
# ============================================================================

CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
CACHE_LOCATION=unique-snowflake

# Alternative: Use Redis for production
# CACHE_BACKEND=django_redis.cache.RedisCache
# REDIS_URL=redis://localhost:6379/1

# ============================================================================
# JWT Token Configuration
# ============================================================================

# Token lifetime in days (configured in settings.py)
# ACCESS_TOKEN_LIFETIME = 1 day
# REFRESH_TOKEN_LIFETIME = 7 days

# ============================================================================
# Application-Specific Settings
# ============================================================================

# Fraud Detection Thresholds
RISK_THRESHOLD_LOW=0.25
RISK_THRESHOLD_MEDIUM=0.50
RISK_THRESHOLD_HIGH=0.75
CRITICAL_ALERT_THRESHOLD=0.75

# ============================================================================
# AWS/Cloud Configuration (Optional)
# ============================================================================

# AWS S3 for media storage
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# ============================================================================
# Sentry Error Tracking (Optional)
# ============================================================================

# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
