# Healthcare Fraud Detection Dashboard - Environment Configuration
# 
# Copy this file to .env and update values for your environment

# API Configuration
# Base URL for all API requests to the fraud detection backend
REACT_APP_API_URL=http://localhost:8000/api

# For production deployment:
# REACT_APP_API_URL=https://api.yourdomain.com/api

# Optional: Enable debug logging
# REACT_APP_DEBUG=true

# Optional: Custom API timeout (milliseconds)
# REACT_APP_API_TIMEOUT=10000

# React App Configuration
REACT_APP_VERSION=1.0.0
REACT_APP_NAME=Fraud Detection Dashboard
